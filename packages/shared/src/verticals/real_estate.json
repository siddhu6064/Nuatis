    },
    { "key": "budget_max", "label": "Budget max ($)", "type": "number", "required": false },
    {
      "key": "target_neighborhoods",
      "label": "Target neighborhoods",
      "type": "text",
      "required": false
    },
    {
      "key": "pre_approval_status",
      "label": "Pre-approval status",
