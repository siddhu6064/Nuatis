# Copy this to .env and fill in values. NEVER commit .env to git.

# Server
PORT=3001
NODE_ENV=development

# Database (Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_URL_POOLED=postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Auth (Clerk)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Telnyx (Phase 2)
TELNYX_API_KEY=KEY...
TELNYX_APP_ID=...

# Deepgram (Phase 2)
DEEPGRAM_API_KEY=...

# ElevenLabs (Phase 2)
ELEVENLABS_API_KEY=...

# Anthropic / Claude (Phase 2)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI embeddings (Phase 3)
OPENAI_API_KEY=sk-...

# Redis / Upstash (Phase 3)
REDIS_URL=redis://...

# AWS S3 (Phase 2)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET_RECORDINGS=nuatis-recordings

# Google Calendar (Phase 1)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Email - Resend (Phase 2)
RESEND_API_KEY=re_...
REDIS_URL=redis://default:your_password@your-host.upstash.io:6379
